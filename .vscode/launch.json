{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MT5 Planner: Run Once",
      "type": "debugpy",
      "request": "launch",
      "module": "mt5_planner",
      "args": ["csv", "--config", "config.json", "--once", "--no-clear"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "MT5 Planner: History",
      "type": "debugpy",
      "request": "launch",
      "module": "mt5_planner",
      "args": ["history", "--config", "config.json", "--limit", "20"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "MT5 Planner: Track Results",
      "type": "debugpy",
      "request": "launch",
      "module": "mt5_planner",
      "args": ["track", "--config", "config.json"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
